---
import { ANALYTICS } from '~/utils/config';

const googleAnalyticsId = ANALYTICS?.vendors?.googleAnalytics?.id;
const partytown = ANALYTICS?.vendors?.googleAnalytics?.partytown ?? false;
const scriptAttrs = partytown ? { type: 'text/partytown' } : {};
const googleAnalyticsInitScript = googleAnalyticsId
  ? `
window.dataLayer = window.dataLayer || [];
function gtag(){window.dataLayer.push(arguments);}
gtag('js', new Date());
gtag('config', ${JSON.stringify(String(googleAnalyticsId))});
`.trim()
  : '';
---

{
  googleAnalyticsId ? (
    <>
      <script
        is:inline
        async
        src={`https://www.googletagmanager.com/gtag/js?id=${String(googleAnalyticsId)}`}
        {...scriptAttrs}
      />
      <script is:inline set:html={googleAnalyticsInitScript} {...scriptAttrs} />
    </>
  ) : null
}
