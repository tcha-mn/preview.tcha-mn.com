---
import { toHTML } from '@portabletext/to-html';
import { urlFor } from '../../../queries/sanity';
import { DateTime } from 'luxon';
import { Icon } from 'astro-icon/components';

import Hero from '../../../components/widgets/Hero.astro';
import Layout from '../../../layouts/PageLayout.astro';
import { getRelatedEvents } from '../../../queries/Events';
import { fetchOne, fetchShowInfo, fetchSlugs } from '../../../queries/TheatreSeasons';
import SanityImage from '../../../components/common/SanityImage.astro';

export async function getStaticPaths() {
  const seasons = await fetchSlugs();
  const paths = seasons.flatMap((season) => season.shows.map((show) => ({ params: { season: season.slug, show } })));
  return paths;
}
export interface Props {
  season: string;
  show: string;
}
const { season, show } = Astro.params;
const showInfo = await fetchShowInfo({ slug: show });
const seasonInfo = await fetchOne({ season });
const events = await getRelatedEvents({ show });
const ogImage = showInfo.hero ? urlFor(showInfo.hero).url() : '';
const metadata = {
  title: `${showInfo.title} | ${seasonInfo.title} | TCHA`,
  description: `Details for ${showInfo.title}, part of the ${seasonInfo.title} theatre season at TCHA.`,
  openGraph: ogImage ? { images: [{ url: ogImage, width: 1200, height: 630 }] } : undefined,
};
const ticketLink = events[0]?.ticket_link;
const hasTicketLink = Boolean(ticketLink);
const hasProgramPdf = Boolean(showInfo.program_pdf);
const youtubeRecordingUrl = showInfo.youtube_recording_url ?? undefined;
const hasYoutubeRecording = Boolean(youtubeRecordingUrl);
const youtubeEmbedUrl = getYoutubeEmbedUrl(youtubeRecordingUrl);

function formatDate(date: DateTime): string {
  return date.toLocaleString(DateTime.DATE_MED_WITH_WEEKDAY);
}

function getYoutubeEmbedUrl(url?: string | null): string | undefined {
  if (!url) {
    return undefined;
  }

  try {
    const parsedUrl = new URL(url);
    const hostname = parsedUrl.hostname.replace(/^www\./, '');
    const isYoutubeHost = hostname === 'youtube.com' || hostname.endsWith('.youtube.com');
    const isShortYoutubeHost = hostname === 'youtu.be';

    if (isShortYoutubeHost) {
      const videoId = parsedUrl.pathname.split('/').filter(Boolean)[0];
      return videoId ? `https://www.youtube.com/embed/${videoId}` : undefined;
    }

    if (!isYoutubeHost) {
      return undefined;
    }

    if (parsedUrl.pathname.startsWith('/embed/')) {
      const videoId = parsedUrl.pathname.split('/').filter(Boolean)[1];
      return videoId ? `https://www.youtube.com/embed/${videoId}` : undefined;
    }

    const videoId = parsedUrl.searchParams.get('v');
    return videoId ? `https://www.youtube.com/embed/${videoId}` : undefined;
  } catch {
    return undefined;
  }
}
---

<Layout metadata={metadata}>
  {/* Hero Widget */}
  <Hero tagline={'Theatre Season: ' + seasonInfo.title}>
    <Fragment slot="image">
      <SanityImage image={showInfo.hero} className="h-full w-full object-cover" />
    </Fragment>
    <Fragment slot="title">{showInfo.title}</Fragment>

    <Fragment slot="subtitle">
      {formatDate(showInfo.date_range.start)} - {formatDate(showInfo.date_range.end)}
    </Fragment>
    <Fragment slot="content">
      {
        (hasTicketLink || hasProgramPdf || hasYoutubeRecording) && (
          <div class="m-4 flex flex-wrap items-center justify-center gap-4">
            {hasTicketLink && (
              <a
                class="btn-secondary bg-secondary text-primary hover:bg-darkMode focus:bg-darkMode dark:hover:bg-primary inline-flex items-center gap-x-1 rounded-lg px-3 py-2 text-center font-medium hover:text-white focus:text-white focus:outline-none"
                href={ticketLink}
              >
                Get Tickets
              </a>
            )}
            {hasProgramPdf && (
              <a
                class="btn-secondary bg-secondary text-primary hover:bg-darkMode focus:bg-darkMode dark:hover:bg-primary inline-flex items-center gap-x-1 rounded-lg px-3 py-2 text-center font-medium hover:text-white focus:text-white focus:outline-none"
                href={showInfo.program_pdf}
              >
                Download Playbill
              </a>
            )}
            {hasYoutubeRecording && (
              <a
                class="btn-secondary bg-secondary text-primary hover:bg-darkMode focus:bg-darkMode dark:hover:bg-primary inline-flex items-center gap-x-1 rounded-lg px-3 py-2 text-center font-medium hover:text-white focus:text-white focus:outline-none"
                href={youtubeRecordingUrl}
                target="_blank"
                rel="noopener noreferrer"
              >
                <Icon name="tabler:brand-youtube" class="-ml-0.5 h-5 w-5" />
                Watch Recording
              </a>
            )}
          </div>
        )
      }
    </Fragment>
  </Hero>
  <section class="mx-auto max-w-4xl px-6 pb-12 sm:px-6 sm:pb-16 lg:pb-20">
    <h3 id="synopsis" class="my-2 text-base font-bold sm:text-xl dark:text-slate-300">Synopsis</h3>
    <p class="my-2" set:html={toHTML(showInfo.description)} />
    {
      youtubeEmbedUrl && (
        <section aria-labelledby="recording" class="my-8">
          <h3 id="recording" class="my-2 text-base font-bold sm:text-xl dark:text-slate-300">
            Recording
          </h3>
          <div class="aspect-video overflow-hidden rounded-lg bg-slate-900 shadow-lg">
            <iframe
              class="h-full w-full"
              src={youtubeEmbedUrl}
              title={`${showInfo.title} recording`}
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
            ></iframe>
          </div>
        </section>
      )
    }
    {
      showInfo.participation_is_open && showInfo.participation && (
        <>
          <h3 class="my-2 text-base font-bold sm:text-xl dark:text-slate-300">Auditions</h3>
          <p class="my-2" set:html={toHTML(showInfo.participation.details)} />
          {showInfo.participation.registration_link && (
            <a
              class="btn-secondary mt-4"
              target="_blank"
              rel="noopener noreferrer"
              href={showInfo.participation.registration_link}
            >
              Audition Information
            </a>
          )}
        </>
      )
    }
    {
      showInfo.gallery?.images?.length > 0 && (
        <div id="gallery" class="container mx-auto my-8 sm:columns-2 md:columns-3 lg:columns-4 xl:columns-5">
          {showInfo.gallery?.images.map((image) => (
            <>
              <a
                href={urlFor(image).url()}
                data-pswp-width={image.asset.metadata.dimensions.width}
                data-pswp-height={image.asset.metadata.dimensions.height}
                target="_blank"
                rel="noopener noreferrer"
              >
                <SanityImage image={image} className="mb-4" />
              </a>
            </>
          ))}
        </div>
      )
    }
    <script>
      import PhotoSwipeLightbox from 'photoswipe/lightbox';
      import 'photoswipe/style.css';

      let lightbox: PhotoSwipeLightbox;

      document.addEventListener('astro:page-load', () => {
        lightbox = new PhotoSwipeLightbox({
          gallery: '#gallery',
          children: 'a',
          pswpModule: () => import('photoswipe'),
        });

        lightbox.init();
      });

      document.addEventListener('astro:before-swap', () => {
        lightbox.destroy();
      });
    </script>
  </section>
</Layout>
